# .gitignore

# --- Environment Variables ---
# Never  upload files containing secret keys or environment variables.
.env
.env.*
backend/.env

# --- Python ---
# Ignore the virtual environment folder.
venv/

# Ignore Python's compiled cache files.
__pycache__/
*.pyc

# --- IDE / Editor specific files ---
# Ignore common editor and OS files.
.vscode/
.idea/
.DS_Store